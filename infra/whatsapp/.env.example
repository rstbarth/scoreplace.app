# Evolution API env vars — configurar no Railway Dashboard como variables.
# NUNCA commitar .env real; este é só template de exemplo.
#
# Docs: https://doc.evolution-api.com/v2/en/install/env

# ─── Server ──────────────────────────────────────────────────────────────
SERVER_TYPE=http
SERVER_PORT=8080
# Railway expõe a URL pública via $RAILWAY_PUBLIC_DOMAIN — o Evolution usa
# essa URL pra montar links de webhook e URLs de QR Code:
SERVER_URL=https://<seu-app>.up.railway.app

# ─── Auth (gera chave aleatória de 32+ chars; será o "API key" pra todos
#         os requests do nosso Cloud Function) ──────────────────────────
AUTHENTICATION_API_KEY=GERE_UMA_CHAVE_RANDOMICA_DE_32_CHARS_AQUI

# ─── Database (PostgreSQL via Railway add-on) ────────────────────────────
# Railway injeta DATABASE_URL ao linkar Postgres. Evolution suporta nativo.
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=${DATABASE_URL}
DATABASE_CONNECTION_CLIENT_NAME=evolution_scoreplace
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false

# ─── Cache (opcional — Redis Railway add-on melhora performance.
#           Sem Redis, Evolution usa cache em memória) ──────────────────
CACHE_REDIS_ENABLED=false
# CACHE_REDIS_URI=${REDIS_URL}
# CACHE_REDIS_PREFIX_KEY=evo_scoreplace
CACHE_LOCAL_ENABLED=true

# ─── Logs ────────────────────────────────────────────────────────────────
LOG_LEVEL=ERROR,WARN
LOG_COLOR=false
LOG_BAILEYS=error

# ─── Localização ─────────────────────────────────────────────────────────
LANGUAGE=pt-BR
DEL_INSTANCE=false

# ─── QR Code (mais tolerante na hora do pareamento inicial) ──────────────
QRCODE_LIMIT=10
QRCODE_COLOR='#10b981'

# ─── Webhook (Cloud Function recebe eventos de delivery — opcional v2) ──
WEBHOOK_GLOBAL_ENABLED=false
# WEBHOOK_GLOBAL_URL=https://<region>-<project>.cloudfunctions.net/onWhatsAppEvent
# WEBHOOK_EVENTS_QRCODE_UPDATED=true
# WEBHOOK_EVENTS_MESSAGES_UPSERT=false
# WEBHOOK_EVENTS_SEND_MESSAGE=true

# ─── Telemetria (opt-out) ───────────────────────────────────────────────
TELEMETRY=false
