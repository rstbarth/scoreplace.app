rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tournaments — public read, authenticated write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles and subcollections
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null;
      }
    }

    // Casual matches — public read (for QR/room code join), authenticated write
    match /casualMatches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Friend requests
    match /friendRequests/{requestId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Mail (for firestore-send-email extension)
    match /mail/{mailId} {
      allow read: if false;
      allow write: if request.auth != null;
    }
  }
}
