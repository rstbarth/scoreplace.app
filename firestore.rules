rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    // Authenticated user's email, lowercased. Empty string when unavailable.
    function authEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower() : '';
    }

    // Caller is an admin of the tournament: creator, current organizer, or
    // an active co-host. All are denormalized into `adminEmails[]` by
    // saveTournament so the rule stays O(1).
    function isTournamentAdmin(data) {
      return authEmail() != ''
        && data.adminEmails is list
        && authEmail() in data.adminEmails;
    }

    // Keys legitimately touched by the enroll/deenroll transactions when run
    // by a non-admin (i.e. a participant joining or leaving). Anything
    // outside this set requires admin rights.
    function isEnrollmentOnlyDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['participants', 'memberEmails', 'status', 'teamOrigins']);
    }

    // Participant of the tournament (uses denormalized memberEmails[]).
    // Required pra que participantes possam lançar/aprovar resultados,
    // marcar check-in, etc., sem precisar virar admin.
    function isTournamentParticipant(data) {
      return authEmail() != ''
        && data.memberEmails is list
        && authEmail() in data.memberEmails;
    }

    // v0.17.24: Diff que participantes podem fazer. Lista positiva expandida
    // após investigação de todos os campos tocados por _advanceWinner,
    // _maybeFinishElimination, _closeRound (Suíço/Liga), auto check-in,
    // logAction, sitOutHistory, etc. — paths que podem rodar como side
    // effect quando participante aprova ou lança placar.
    function isParticipantBracketDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          // Bracket / scoring / aprovação de resultado
          'matches', 'rounds', 'groups', 'rodadas', 'thirdPlaceMatch',
          'currentStage', 'classification', 'standings',
          // Suíço (transição de stage quando última rodada fecha)
          'swissStandings', 'swissRoundsData', 'swissEliminated',
          // Liga / Rei-Rainha
          'sitOutHistory', 'lastAutoDrawAt',
          // Visibilidade do sorteio (set quando rodada fecha)
          'drawVisibility',
          // Check-in / presença / lista de espera em torneio
          'checkedIn', 'absent', 'tournamentStarted',
          'standbyParticipants', 'waitlist',
          // Activity log (logAction escreve em t.history)
          'history',
          // Timestamps
          'updatedAt', 'lastModified',
          // Liga: toggle ativado/desativado pra próximo sorteio
          'ligaActive', 'ligaInactive',
          // Polls: votação de decisão (cada participante vota uma vez)
          'pollNotifications', 'polls', 'activePollId',
          // Categorias notificadas (auto-assign comunica ao participante)
          'categoryNotifications',
          // Flags internas setadas em fim de torneio / transições
          '_finishNotified', '_roundCloseAt',
          // Status — pode mudar pra 'finished' quando última partida aprovada
          'status',
          // Inscrição — overlap com isEnrollmentOnlyDiff
          'participants', 'memberEmails', 'teamOrigins'
        ]);
    }

    // ─── Tournaments ─────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      // Anonymous users: only public tournaments. Authenticated users may
      // read any tournament (needed for invite links and enroll/deenroll
      // transactions, which have to read before writing). Private
      // tournaments remain hidden from unauth visitors.
      allow read: if (resource.data.isPublic == true) || (request.auth != null);

      // Create: the caller must be the declared creator. Prevents forging
      // tournaments on someone else's behalf.
      allow create: if request.auth != null
        && request.resource.data.creatorEmail is string
        && request.resource.data.creatorEmail.lower() == authEmail();

      // Update permitido em 3 caminhos:
      //   1. Admin (creator/organizer/co-host) — qualquer mudança
      //   2. Qualquer authed pode fazer enrollment-only diff (entrar/sair)
      //   3. Participante pode atualizar campos do bracket (placar, check-in,
      //      aprovação de resultado, voto em poll, etc.) — lista positiva
      //      em isParticipantBracketDiff. Bloqueia mudanças em nome/datas/
      //      formato/regras/organizador/etc. mesmo pra participantes.
      allow update: if request.auth != null
        && (
          isTournamentAdmin(resource.data)
          || isEnrollmentOnlyDiff()
          || (isTournamentParticipant(resource.data) && isParticipantBracketDiff())
        );

      // Delete: admins only.
      allow delete: if request.auth != null && isTournamentAdmin(resource.data);
    }

    // ─── User profiles ───────────────────────────────────────────────────────
    // Diff that only touches the friend-relationship arrays. Used to let a
    // caller modify another user's friends / friendRequestsReceived /
    // friendRequestsSent arrays WITHOUT being able to touch profile fields.
    // The sendFriendRequest / accept / reject / cancel flows need this because
    // each one updates the OTHER party's arrays.
    function isFriendArrayDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['friends', 'friendRequestsSent', 'friendRequestsReceived']);
    }
    match /users/{userId} {
      // Authenticated only — strips PII (email, phone, preferredCeps,
      // fcmToken, etc.) from anonymous visitors. Needed for friend search
      // (searchUsers range query) and participant detail views.
      allow read: if request.auth != null;

      // Create: only the user themselves (first-time profile creation).
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update: owner may touch anything; any other authenticated user may
      // update ONLY the three friend arrays (so sendFriendRequest can add
      // the caller's uid to the target's friendRequestsReceived, accept can
      // add caller to target's friends, etc.). Prevents cross-user edits of
      // profile PII while keeping the friendship flow working.
      allow update: if request.auth != null
        && (request.auth.uid == userId || isFriendArrayDiff());

      // Delete: owner only.
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Notifications — senders create (cross-user), owner manages.
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Match history (stats across tournaments + casual matches) — only
      // the user themselves, same as profile.
      match /matchHistory/{matchId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Templates — only owner.
      match /templates/{templateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Trophies + milestones — owner only (backfill uses Admin SDK, bypasses rules).
      match /trophies/{trophyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /milestones/{milestoneId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Casual matches ──────────────────────────────────────────────────────
    // Public read so anonymous QR / room-code joins work — no PII. Writes
    // require auth; the claim-slot transaction adds uid to playerUids, so
    // we can't scope update to "already-in-playerUids" without breaking the
    // join flow. Left permissive for authenticated users.
    match /casualMatches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Friend requests ─────────────────────────────────────────────────────
    // TODO(security): scope read/write to the request's from/to uids once
    // the doc structure is cemented. Authed-only for now.
    match /friendRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // ─── Mail (firestore-send-email extension) ───────────────────────────────
    match /mail/{mailId} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ─── Magic Links wrapper (v1.0.30-beta) ──────────────────────────────────
    // Cloud Function `sendMagicLink` cria docs aqui com o link Firebase
    // assinado. Usuário NÃO autenticado clica no email, abre /?ml=TOKEN no
    // browser, e o JS do app lê esse doc pra resolver o firebaseLink real e
    // redirecionar. Token é 24 chars random base64url — segredo suficiente
    // pra leitura pública (igual unlisted YouTube link). Escrita só via
    // Admin SDK (Cloud Function bypassa rules).
    match /magicLinks/{token} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Presences (check-ins + planned "I'll play here") ─────────────────────
    // Any authenticated user may read; client filters by visibility and friends.
    // Create: must match caller's uid. Update/delete: owner only.
    // TODO(security): lock reads to friends + public via a denormalized
    // friendUids[] once the feature is validated.
    match /presences/{presenceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ─── Venues (community listings, opcionalmente reivindicáveis) ───────────
    // Qualquer usuário autenticado pode cadastrar um local novo; o dono
    // formal (ownerUid) é uma reivindicação opcional. Leitura pública para
    // descoberta anônima.
    //
    // Create:
    //   - authed, createdByUid == auth.uid
    //   - ownerUid pode ser null (cadastro comunitário) ou == auth.uid
    //     (reivindicação na criação).
    // Update:
    //   - dono formal (ownerUid == auth.uid) pode alterar tudo
    //   - se não há dono, qualquer authed pode alterar desde que não promova
    //     outra pessoa a dono (ownerUid deve permanecer null ou virar self)
    //   - qualquer authed pode incrementar viewCount/lastViewedAt
    // Delete: dono formal (ownerUid == auth.uid).
    function isViewCountBump() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['viewCount', 'lastViewedAt']);
    }
    function venueOwnershipOk() {
      return request.resource.data.ownerUid == null
        || request.resource.data.ownerUid == request.auth.uid;
    }
    match /venues/{venueId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid
        && venueOwnershipOk();
      allow update: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          || isViewCountBump()
          || (resource.data.ownerUid == null && venueOwnershipOk())
        );
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      // Avaliações do local: estrelas (1-5) + texto opcional. Um review por
      // usuário (doc id = uid). Leitura pública para busca anônima. Criar e
      // atualizar só quem é o próprio autor; dono do venue pode moderar.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && reviewId == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid;
        // Delete: próprio autor OU dono do venue (moderação).
        allow delete: if request.auth != null
          && (
            resource.data.uid == request.auth.uid
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
          );
      }

      // Quadras do local:
      //
      // DUAS FASES:
      // 1. FASE COLABORATIVA (venue sem owner): qualquer autenticado adiciona;
      //    cada contribuidor pode editar/apagar APENAS suas próprias entradas.
      // 2. FASE CLAIMED (venue com ownerUid): o dono é o único que adiciona,
      //    edita e apaga quadras. Quando um usuário reivindica o local, ele
      //    "assume tudo" — inclusive as entradas cadastradas pela comunidade
      //    ficam sob sua gestão exclusiva. Contributors originais perdem
      //    acesso de edição (a entrada permanece, mas gerenciada pelo dono).
      //
      // CREATE: permitido se (a) venue não tem dono E o criador é o
      //   contributor, OU (b) venue tem dono e esse dono é o criador.
      // UPDATE/DELETE: mesmo princípio — contributor só quando não há dono;
      //   dono sempre quando existe.
      match /courts/{courtId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.contributorUid == request.auth.uid
          && request.resource.data.sport is string
          && request.resource.data.count is int
          && request.resource.data.count >= 1
          && request.resource.data.count <= 999
          && (
            // Venue sem dono: qualquer autenticado contribui
            !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
            // OU: venue tem dono e o criador É o dono
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
          );
        allow update: if request.auth != null
          && (
            // Venue tem dono: só o dono edita (assume tudo, incluindo
            // entradas que foram feitas por contribuidores antes)
            get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
            // OU: venue sem dono e usuário é o contributor original
            || (
              (
                !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
                || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
              )
              && resource.data.contributorUid == request.auth.uid
            )
          );
        allow delete: if request.auth != null
          && (
            get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
            || (
              (
                !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
                || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
              )
              && resource.data.contributorUid == request.auth.uid
            )
          );
      }
    }
  }
}
